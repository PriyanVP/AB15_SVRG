firmware/.metadata/

# Ignore folder with binaries for firmware
firmware/mcu_esw/TriCore Debug (TASKING)/*

# .. except certain files
!firmware/mcu_esw/TriCore Debug (TASKING)/*.hex
!firmware/mcu_esw/TriCore Debug (TASKING)/*.elf
!firmware/mcu_esw/TriCore Debug (TASKING)/*.map