<Application x:Class="AB15_GUI.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AB15_GUI.WPF"
             xmlns:vm="clr-namespace:AB15_GUI.WPF.ViewModels"
             xmlns:shared="clr-namespace:AB15_GUI.WPF.Views.Components"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary x:Name="LightTheme" Source="Views/Themes/Light.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <shared:SharedThemeState x:Key="SharedThemeState"/>
            <vm:ViewModelLocator x:Key="ViewModelLocator"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
