<Page x:Class="AB15_GUI.WPF.Views.Components.TestAnimation"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AB15_GUI.WPF.Views.Components"
      mc:Ignorable="d" 
      MinHeight="40" MinWidth="40"
      Title="TestAnimation">

    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <!--<Border Grid.Column="1" BorderThickness="1" BorderBrush="Red"/>-->
        <Line Grid.Column="1" X1="0" X2="0" Y1="0" Y2="{Binding ElementName=MainGrid, Path=Height}" Stroke="Red" StrokeThickness="1"/>
        <local:animatedDataFly x:Name="spark" Grid.Column="1" FillColor="Green" HorizontalAlignment="Center"/>
    </Grid>
</Page>
