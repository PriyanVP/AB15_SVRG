<Window x:Class="AB15_GUI.WPF.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:custom="clr-namespace:AB15_GUI.WPF.Views.Components"
        xmlns:local="clr-namespace:AB15_GUI.WPF.Views"
        mc:Ignorable="d"
        Title="Bosch AB15" Height="650" Width="1000"
        Icon="Resources/bosch.ico">
    <Grid Background="{DynamicResource BackGroung}">
        <!--Separate control group-->
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" MinHeight="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto" MinHeight="20"/>
        </Grid.RowDefinitions>

        <!--Top panel group-->
        <Grid Grid.Row="0" Background="{DynamicResource TopPanel.Background}">
            <!--User menu control group-->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="auto" MinWidth="20"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="auto" MinWidth="20"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="auto" MinWidth="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto" MinWidth="20"/>
                <ColumnDefinition Width="5"/>
            </Grid.ColumnDefinitions>
            
            <!--Save/Load menu-->
            <Menu Grid.Column="1" FontSize="20">
                <MenuItem Template="{StaticResource VsMenuTop}" Header="File">
                    <MenuItem Template="{StaticResource VsMenuSub}" Header="Load Register settings"/>
                    <MenuItem Template="{StaticResource VsMenuSub}" Header="Save Register settings"/>
                </MenuItem>
            </Menu>
            
            <!--Links menu-->
            <Menu Grid.Column="3" FontSize="20">
                <MenuItem Template="{StaticResource VsMenuTop}" Header="More" >
                    <MenuItem Template="{StaticResource VsMenuSub}" Header="RA1xx Documantation"/>
                    <MenuItem Template="{StaticResource VsMenuSub}" Header="RA1xx GUI User Manual"/>
                    <MenuItem Template="{StaticResource VsMenuSub}" Header="RA1xx TCD"/>
                    <MenuItem Template="{StaticResource VsMenuSub}" Header="RA1xx Application Note"/>
                    <MenuItem Template="{StaticResource VsMenuSub}" Header="RA1xx Register Maps"/>
                    <MenuItem Template="{StaticResource VsMenuSub}" Header="Sensor details"/>
                </MenuItem>
            </Menu>
        </Grid>

        <!--Middle panel group-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" MinWidth="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--<Border Grid.Column="0" BorderThickness="0,1,1,1" BorderBrush="{DynamicResource Menu.SeparateLine}"/>-->

            <!--Subsection-->
            <Grid Grid.Column="0" x:Name="MenuPanel" Margin="3,3" Background="{DynamicResource Menu.Background}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" MinWidth="160"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" MinHeight="20"/>
                    <RowDefinition Height="auto" MinHeight="20"/>
                    <RowDefinition Height="auto" MinHeight="20"/>
                    <RowDefinition Height="auto" MinHeight="20"/>
                    <RowDefinition Height="auto" MinHeight="20"/>
                    <RowDefinition Height="auto" MinHeight="20"/>
                    <RowDefinition Height="auto" MinHeight="20"/>
                    <RowDefinition Height="auto" MinHeight="20"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto" MinHeight="20"/>
                </Grid.RowDefinitions>

                <ToggleButton Style="{DynamicResource MenuToggleButtonTemplate}" x:Name="MenuSizeToggle" IsChecked="True"
                        Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Grid.Column="0" Source="{DynamicResource Ico.menu}" 
                               Width="30" 
                               RenderTransformOrigin="0.5,0.5" 
                               HorizontalAlignment="Stretch" VerticalAlignment="Center">
                            <Image.RenderTransform>
                                <RotateTransform x:Name="MenuImage" CenterX="0.5" CenterY="0.5"/>
                            </Image.RenderTransform>
                        </Image>
                        <TextBlock Text="Menu" FontSize="20" Grid.Column="1" Style="{DynamicResource TextBlockStyle}"/>
                        
                    </Grid>
                    <ToggleButton.Triggers>
                        <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation 
                                        Storyboard.TargetName="MenuPanel"
                                        Storyboard.TargetProperty="Width"
                                        BeginTime="0:0:0"
                                        From="160" To="40"
                                        Duration="0:0:0.2"/>
                                    <DoubleAnimation
                                        Storyboard.TargetName="MenuImage"
                                        Storyboard.TargetProperty="Angle"
                                        To="90"
                                        Duration="0:0:0.2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="ToggleButton.Checked">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation 
                                        Storyboard.TargetName="MenuPanel"
                                        Storyboard.TargetProperty="Width"
                                        BeginTime="0:0:0"
                                        To="166" From="46"
                                        Duration="0:0:0.2"/>
                                    <DoubleAnimation
                                        Storyboard.TargetName="MenuImage"
                                        Storyboard.TargetProperty="Angle"
                                        To="0"
                                        Duration="0:0:0.2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ToggleButton.Triggers>
                </ToggleButton>

                <!--Subsection Definition-->
                <Button Grid.Row="1" Style="{DynamicResource MenuButtons}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Source="{DynamicResource Ico.home}" Grid.Column="0" Width="30"/>
                        <TextBlock Text="Home" FontSize="20" Grid.Column="1" Style="{DynamicResource TextBlockStyle}"/>

                    </Grid>
                </Button>

                <Button Grid.Row="2" Style="{DynamicResource MenuButtons}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Source="{DynamicResource Ico.zoom}" Grid.Column="0" Width="30"/>
                        <TextBlock Text="SPI Learning" FontSize="20" Grid.Column="1" Style="{DynamicResource TextBlockStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="3" Style="{DynamicResource MenuButtons}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Source="{DynamicResource Ico.whatchdog}" Grid.Column="0" Width="30"/>
                        <TextBlock Text="Watchdog" FontSize="20" Grid.Column="1" Style="{DynamicResource TextBlockStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="4" Style="{DynamicResource MenuButtons}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Source="{DynamicResource Ico.airbag}" Grid.Column="0" Width="30"/>
                        <TextBlock Text="Firing" FontSize="20" Grid.Column="1" Style="{DynamicResource TextBlockStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="5" Style="{DynamicResource MenuButtons}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Source="{DynamicResource Ico.chip}" Grid.Column="0" Width="30"/>
                        <TextBlock Text="RA1xx Data" FontSize="20" Grid.Column="1" Style="{DynamicResource TextBlockStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="6" Style="{DynamicResource MenuButtons}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Source="{DynamicResource Ico.sensor}" Grid.Column="0" Width="30"/>
                        <TextBlock Text="Sensor" FontSize="20" Grid.Column="1" Style="{DynamicResource TextBlockStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="7" Click="Button_Click" Style="{DynamicResource MenuButtons}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Source="{DynamicResource ico.config}" Grid.Column="0" Width="30"/>
                        <TextBlock Text="Diagnostics" FontSize="20" Grid.Column="1" Style="{DynamicResource TextBlockStyle}"/>
                    </Grid>
                </Button>

                <Grid Grid.Row="8" VerticalAlignment="Bottom">
                    <!--TODO Add animated status panel-->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <custom:testAnimationRev2 x:Name="animationTest1" Grid.Row="1" Height="20" 
                                                  HorizontalAlignment="Left" 
                                                  FlyColor="{DynamicResource Animation.Arrow}" 
                                                  BorderColor="{DynamicResource Animation.Lines}" 
                                                  IsAnimationEnabled="{Binding MCUConnectionStatus}"/>

                        <custom:testAnimationRev2 x:Name="animationTest2" Grid.Row="3" Height="20" 
                                                  HorizontalAlignment="Left" 
                                                  FlyColor="{DynamicResource Animation.Arrow}" 
                                                  BorderColor="{DynamicResource Animation.Lines}" 
                                                  IsAnimationEnabled="{Binding ABConnectionStatus}"/>

                        <Border Grid.Row="0" BorderThickness="1" 
                                BorderBrush="{DynamicResource Animation.Lines}" 
                                Background="{DynamicResource Menu.Background}" 
                                CornerRadius="5" HorizontalAlignment="Left" 
                                Width="40">
                            <TextBlock Text="PC" HorizontalAlignment="Center" FontSize="16" Style="{DynamicResource TextBlockStyle}"/>
                        </Border>

                        <Border Grid.Row="2" BorderThickness="1" 
                                BorderBrush="{DynamicResource Animation.Lines}" 
                                Background="{DynamicResource Menu.Background}" 
                                CornerRadius="5" HorizontalAlignment="Left" 
                                Width="40">
                            <TextBlock Text="MCU" HorizontalAlignment="Center" FontSize="16" Style="{DynamicResource TextBlockStyle}"/>
                        </Border>

                        <Border Grid.Row="4" BorderThickness="1" 
                                BorderBrush="{DynamicResource Animation.Lines}" 
                                Background="{DynamicResource Menu.Background}" 
                                CornerRadius="5" HorizontalAlignment="Left" 
                                Width="40">
                            <TextBlock Text="AB" HorizontalAlignment="Center" FontSize="16" Style="{DynamicResource TextBlockStyle}"/>
                        </Border>
                    </Grid>
                </Grid>
                
            </Grid>
        </Grid>

        <!--Bottom panel group-->
        <Grid Grid.Row="2" Background="{DynamicResource BottonPanel.Background}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="auto" MinWidth="20"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="auto" MinWidth="20"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="auto" MinWidth="20"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="auto" MinWidth="20"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="auto" MinWidth="20"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="auto" MinWidth="20"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Style="{DynamicResource TextBlockStyle}" Text="GUI:" Grid.Column="1"/>
            <TextBlock Style="{DynamicResource TextBlockStyle}" Text="MCU:" Grid.Column="5"/>
            <TextBlock Style="{DynamicResource TextBlockStyle}" Text="AB1xx:" Grid.Column="9"/>

            <TextBlock Style="{DynamicResource TextBlockStyle}" Text="{Binding GUIVersion}" Grid.Column="3"/>
            <TextBlock Style="{DynamicResource TextBlockStyle}" Text="{Binding MCUVersion}" Grid.Column="7"/>
            <TextBlock Style="{DynamicResource TextBlockStyle}" Text="{Binding ABID}" Grid.Column="9"/>
        </Grid>
    </Grid>
</Window>
