<Page x:Class="AB15_GUI.WPF.Views.SPILearning"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:cnvrt="clr-namespace:AB15_GUI.WPF.Views.Converters" 
      xmlns:local="clr-namespace:AB15_GUI.WPF.Views"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="1100"
      Title="SPILearning"
      DataContext="{Binding SPILearningViewModel, Source={StaticResource ViewModelLocator}}">

    <Page.Resources>
        <cnvrt:BitToTextConverter x:Key="BitToTextConverter"/>
        <cnvrt:BoolToIntConverter x:Key="BoolToIntConverter"/>
        <cnvrt:BoolToRWConverter x:Key="BoolToRWConverter"/>
        <cnvrt:HexToIntConverter x:Key="HexToIntConverter"/>
        <cnvrt:HelpMessageConverter x:Key="HelpMessageConverter"/>
    </Page.Resources>
    
    <Grid Background="{DynamicResource UI.BackGround}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="5"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="5"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="5"/>
        </Grid.RowDefinitions>

        <!--#region Top section-->
        <Grid Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto" MinWidth="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- #region Controls-->
            <TextBlock  Grid.Row="0" Grid.Column="1"
                        FontSize="16" Margin="3"
                        VerticalAlignment="Bottom" HorizontalAlignment="Left"
                        Text="Address:"
                        Style="{DynamicResource CustomTextBlock}"
                        ToolTipService.ToolTip="{Binding Path=HelpMsgDictionary, Converter={StaticResource HelpMessageConverter}, ConverterParameter='Address', Mode=OneWay}"
	                    ToolTipService.IsEnabled="{Binding ElementName=HelpProviderToggleButton, Path=IsChecked}"/>
            
            <TextBlock  Grid.Row="0" Grid.Column="2"
                        FontSize="16" Margin="3"
                        VerticalAlignment="Bottom" HorizontalAlignment="Right"
                        Text="0x"
                        Style="{DynamicResource CustomTextBlock}"/>

            <TextBox    Grid.Row="0" Grid.Column="3"
                        Style="{DynamicResource TextBoxStyle}"
                        IsEnabled="{Binding IsSPILearningEn}"
                        Text="{Binding Path=RefToActiveRecord.MOSI.Address, Converter={StaticResource HexToIntConverter}, Mode=TwoWay}"
                        Name="AddressTextBox"
                        PreviewTextInput="TextBox_PreviewTextInput">
            </TextBox>
            
            <TextBlock  Grid.Row="1" Grid.Column="1"
                        FontSize="16" Margin="3"
                        VerticalAlignment="Bottom" HorizontalAlignment="Left"
                        Text="Data:"
                        Style="{DynamicResource CustomTextBlock}"
                        ToolTipService.ToolTip="{Binding Path=HelpMsgDictionary, Converter={StaticResource HelpMessageConverter}, ConverterParameter='MOSIData', Mode=OneWay}"
	                    ToolTipService.IsEnabled="{Binding ElementName=HelpProviderToggleButton, Path=IsChecked}"/>

            <TextBlock  Grid.Row="1" Grid.Column="2"
                        FontSize="16" Margin="3"
                        VerticalAlignment="Bottom" HorizontalAlignment="Right"
                        Text="0x"
                        Style="{DynamicResource CustomTextBlock}"/>

            <TextBox    Grid.Row="1" Grid.Column="3"
                        Text="{Binding Path=RefToActiveRecord.MOSI.Data, Converter={StaticResource HexToIntConverter}, Mode=TwoWay}"
                        Name="DataTextBox"
                        PreviewTextInput="TextBox_PreviewTextInput">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Path=IsSPILearningEn}" Value="True" />
                                            <Condition Binding="{Binding Path=IsWriteRegisterSelected}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="IsEnabled" Value="True" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
            </TextBox>
            
            <StackPanel Orientation="Horizontal"
                        Grid.Row="2" Grid.Column="1">
                <TextBlock  Text="RAW: " FontSize="16" Margin="3"
                            VerticalAlignment="Center"
                            Style="{DynamicResource CustomTextBlock}"/>
                
                <CheckBox   x:Name="isRawFormat"
                            Style="{DynamicResource ToggleSwitchStyle}"
                            IsEnabled="{Binding IsSPILearningEn}"
                            IsChecked="{Binding IsRawSPISelected}"
                            Checked="isRawFormat_Checked"
                            Unchecked="isRawFormat_Unchecked"
                            ToolTipService.ToolTip="{Binding Path=HelpMsgDictionary, Converter={StaticResource HelpMessageConverter}, ConverterParameter='IsRawSPISelected', Mode=OneWay}"
	                        ToolTipService.IsEnabled="{Binding ElementName=HelpProviderToggleButton, Path=IsChecked}"/>
            </StackPanel>

            <TextBlock  Grid.Row="2" Grid.Column="2"
                        FontSize="16" Margin="3"
                        VerticalAlignment="Bottom" HorizontalAlignment="Right"
                        Text="0x"
                        Style="{DynamicResource CustomTextBlock}"
                        Name="RawHexText" Visibility="Hidden" />

            <TextBox    Grid.Row="2" Grid.Column="3"
                        x:Name="RawFormatTextBox"
                        IsEnabled="{Binding IsSPILearningEn}"
                        Text="{Binding Path=RefToActiveRecord.MOSI.RawMOSI, Converter={StaticResource HexToIntConverter}, Mode=TwoWay}"
                        Visibility="Hidden"
                        Style="{DynamicResource TextBoxStyle}"
                        PreviewTextInput="TextBox_PreviewTextInput" 
                        >
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="LostFocus">
                                <i:InvokeCommandAction Command="{Binding Path=RawValueUpdatedCommand}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
            </TextBox>


            <Grid       Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="1"
                        x:Name="ReadWriteChooseField">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="25"/>
                </Grid.ColumnDefinitions>

                <CheckBox   Grid.Column="0"
                            x:Name="WritingCheckBox"
                            Style="{DynamicResource ToggleSwitchStyle}"
                            IsChecked="{Binding IsWriteRegisterSelected}"
                            IsEnabled="{Binding IsSPILearningEn}"
                            HorizontalAlignment="Center" Margin="3"
                            ToolTipService.ToolTip="{Binding Path=HelpMsgDictionary, Converter={StaticResource HelpMessageConverter}, ConverterParameter='ReadWriteSwitch', Mode=OneWay}"
	                        ToolTipService.IsEnabled="{Binding ElementName=HelpProviderToggleButton, Path=IsChecked}"/>

                <TextBlock  Grid.Column="1"
                            FontSize="16" Margin="3"
                            VerticalAlignment="Center" HorizontalAlignment="Left"
                            Foreground="{DynamicResource Foreground.Default}" >
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Read" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=WritingCheckBox, Path=IsChecked}" Value="True">
                                    <Setter Property="Text" Value="Write" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ToggleButton Style="{DynamicResource SimpleToggleButton}" 
                      x:Name="HelpProviderToggleButton"
                      HorizontalAlignment="Right"
                      Content="?" Grid.Row="0" Grid.Column="2" 
                      BorderThickness="1" Margin="2" Width="20" Height="20"
                      ToolTip="Enable/Disable the UI elements help messages" />

            </Grid>


            <ComboBox   Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="1"
                        ItemsSource="{Binding SelectedASICToSend}"
                        IsEnabled="{Binding IsSPILearningEn}"
                        MinWidth="100" Margin="3"
                        ToolTipService.ToolTip="{Binding Path=HelpMsgDictionary, Converter={StaticResource HelpMessageConverter}, ConverterParameter='DeviceIDSelector', Mode=OneWay}"
	                    ToolTipService.IsEnabled="{Binding ElementName=HelpProviderToggleButton, Path=IsChecked}"/>

            <Button     Grid.Row="3" Grid.Column="3" Grid.ColumnSpan="1"
                        Style="{DynamicResource SimpleButton}"
                        Command="{Binding SPICommand}"
                        IsEnabled="{Binding SPICommandCommandEn}"
                        Content="Execute command" FontSize="16"
                        Margin="2"
                        ToolTipService.ToolTip="{Binding Path=HelpMsgDictionary, Converter={StaticResource HelpMessageConverter}, ConverterParameter='SPICommand', Mode=OneWay}"
	                    ToolTipService.IsEnabled="{Binding ElementName=HelpProviderToggleButton, Path=IsChecked}"/>
            <!--#endregion-->

            <!--#region Message decoded-->
            <Grid Grid.Row="0" Grid.RowSpan="4" Grid.Column="4" 
                  VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
