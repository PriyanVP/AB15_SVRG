                                       Text="CRC" HorizontalAlignment="Center">
                </TextBlock>

                <TextBlock Grid.Row="1" Grid.Column="6" FontSize="14"
                                       Text="RAW" HorizontalAlignment="Center">
                </TextBlock>
                <!-- #endregion -->

                <!-- #region Table content -->
                <ListView Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="6" Name="MISOTableTableView" 
                                ItemsSource="{Binding MISOTable}"
                                ItemContainerStyle="{DynamicResource ListViewItemStyle}" 
                                IsEnabled="{Binding IsConfigControlsEnabled}"
                                FontSize="20">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="5" />
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="2"/>
                                    <RowDefinition Height="1"/>
                                </Grid.RowDefinitions>

                                <Canvas Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Background="{DynamicResource UI.SeparateLine}"/>

                                <!-- Cell with number -->
                                <TextBlock  Grid.Column="1" Margin="0,0,5,0" 
                                            VerticalAlignment="Center"
                                            FontSize="14" HorizontalAlignment="Center"
                                            Text="{Binding number}">
                                </TextBlock>

                                <!-- Cell with address -->
                                <TextBlock  Grid.Column="2" Margin="0,0,5,0" 
                                            VerticalAlignment="Center"
                                            FontSize="14" HorizontalAlignment="Center"
                                            Text="{Binding address, StringFormat={}{0:x}}">
                                </TextBlock>

                                <!-- Cell with R/W -->
                                <TextBlock  Grid.Column="3"  Margin="0,0,5,0" 
                                            VerticalAlignment="Center"
                                            FontSize="14" HorizontalAlignment="Center"
                                            Text="">
                                    <!--TODO place convertor-->
                                </TextBlock>

                                <!-- Cell with Data -->
                                <TextBlock  Grid.Column="1" Margin="0,0,5,0" 
                                            VerticalAlignment="Center"
                                            FontSize="14" HorizontalAlignment="Center"
                                            Text="{Binding data, StringFormat={}{0:x}}">
                                </TextBlock>

                                <!-- Cell with CRC -->
                                <TextBlock  Grid.Column="1" Margin="0,0,5,0" 
                                            VerticalAlignment="Center"
                                            FontSize="14" HorizontalAlignment="Center"
                                            Text="{Binding crc, StringFormat={}{0:x}}">
                                </TextBlock>

                                <!-- Cell with RAW -->
                                <TextBlock  Grid.Column="1" Margin="0,0,5,0" 
                                            VerticalAlignment="Center"
                                            FontSize="14" HorizontalAlignment="Center"
                                            Text="{Binding raw, StringFormat={}{0:x}}">
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <!-- #endregion -->
            </Grid>
        </Border>
        <!-- #endregion -->

    </Grid>
</Page>
