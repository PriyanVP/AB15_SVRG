                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Style="{DynamicResource CustomTextBlock}"
                           ToolTipService.ToolTip="{Binding Path=HelpMsgDictionary, Converter={StaticResource HelpMessageConverter}, ConverterParameter='NA', Mode=OneWay}"
	                       ToolTipService.IsEnabled="{Binding ElementName=HelpProviderToggleButton, Path=IsChecked}"/>

