                                            VerticalAlignment="Center"
                                            FontSize="14" HorizontalAlignment="Center"
                                            Text="{Binding raw, StringFormat={}{0:x}}">
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
