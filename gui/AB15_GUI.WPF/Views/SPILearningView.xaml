<Page x:Class="AB15_GUI.WPF.Views.SPILearning"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:cnvrt="clr-namespace:AB15_GUI.WPF.Views.Converters" 
      xmlns:local="clr-namespace:AB15_GUI.WPF.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="1100"
      Title="SPILearning"
      DataContext="{Binding SPILearningViewModel, Source={StaticResource ViewModelLocator}}">

    <Page.Resources>
        <cnvrt:TextToBitConverter x:Key="TextToBitConverter"/>
    </Page.Resources>
    
    <Grid Background="{DynamicResource UI.BackGround}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="5"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="5"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="5"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto" MinWidth="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock  Grid.Row="0" Grid.Column="0"
                        FontSize="20" Margin="3"
                        HorizontalAlignment="Right"
                        Text="Address:"/>
            
            <TextBox    Grid.Row="0" Grid.Column="1"
                        Style="{DynamicResource TextBoxStyle}"
                        IsEnabled="{Binding IsSPIControlsEnabled}"
                        Name="AddressTextBox">
            </TextBox>
            
            <TextBlock  Grid.Row="1" Grid.Column="0"
                        FontSize="20" Margin="3"
                        HorizontalAlignment="Right"
                        Text="Data:"/>

            <TextBox    Grid.Row="1" Grid.Column="1"
                        Style="{DynamicResource TextBoxStyle}"
                        IsEnabled="{Binding IsSPIControlsEnabled}"
                        Name="DataTextBox">
            </TextBox>

            <Grid       Grid.Row="2" Grid.Column="1"
                        Grid.ColumnSpan="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock  Grid.Column="0"
                            FontSize="20" Margin="3"
                            HorizontalAlignment="Right"
                            Text="Read:"/>

                <CheckBox   Grid.Column="1"
                            x:Name="ReadingCheckBox"
                            Style="{DynamicResource ToggleSwitchStyle}"
                            IsChecked="{Binding IsReadingCustomCommand}"
                            IsEnabled="{Binding IsSPIControlsEnabled}"
                            HorizontalAlignment="Left" Margin="5"
                            Checked="CheckBox_Checked"
                            Unchecked="CheckBox_Checked"/>

                <TextBlock  Grid.Column="2"
                            FontSize="20" Margin="3"
                            HorizontalAlignment="Right"
                            Text="Write:"/>

                <CheckBox   Grid.Column="3"
                            x:Name="WritingCheckBox"
                            Style="{DynamicResource ToggleSwitchStyle}"
                            IsChecked="{Binding IsWritingCustomCommand}"
                            IsEnabled="{Binding IsSPIControlsEnabled}"
                            HorizontalAlignment="Left" Margin="5"
                            Checked="CheckBox_Checked"
                            Unchecked="CheckBox_Checked"/>
            </Grid>


            <ComboBox   ItemsSource="{Binding SelectedASICToSend}"
                        IsEnabled="{Binding IsSPIControlsEnabled}"
                        MinWidth="100" Margin="3"
                        Grid.Row="3" Grid.Column="0"/>

            <Button     Grid.Row="3" Grid.Column="1"
                        Style="{DynamicResource SimpleButton}"
                        Command="{Binding ExecuteCustomCommand}"
                        IsEnabled="{Binding IsSPIControlsEnabled}"
                        Content="Execute command" FontSize="20"
                        Margin="2"/>

            <Grid       Grid.Row="0" Grid.RowSpan="3" Grid.Column="2"
                        HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border BorderBrush="{DynamicResource SimpleButton.BorderBrush}"
                        BorderThickness="2"
                        Grid.Column="0" Grid.ColumnSpan="10"
                        Grid.Row="0" Grid.RowSpan="3"/>
                
                <Border BorderBrush="{DynamicResource SimpleButton.BorderBrush}"
                        BorderThickness="1"
                        Grid.Column="0" Grid.ColumnSpan="32"
                        Grid.Row="1" Grid.RowSpan="1"/>
                
                <Border BorderBrush="{DynamicResource SimpleButton.BorderBrush}"
                        BorderThickness="2"
                        Grid.Column="0" Grid.ColumnSpan="10"
                        Grid.Row="0" Grid.RowSpan="3"/>

                <Border BorderBrush="{DynamicResource SimpleButton.BorderBrush}"
                        BorderThickness="2"
                        Grid.Column="10" Grid.ColumnSpan="1"
                        Grid.Row="0" Grid.RowSpan="3"/>

                <Border BorderBrush="{DynamicResource SimpleButton.BorderBrush}"
                        BorderThickness="2"
                        Grid.Column="11" Grid.ColumnSpan="16"
                        Grid.Row="0" Grid.RowSpan="3"/>

                <Border BorderBrush="{DynamicResource SimpleButton.BorderBrush}"
                        BorderThickness="2"
                        Grid.Column="27" Grid.ColumnSpan="3"
                        Grid.Row="0" Grid.RowSpan="3"/>

                <Border BorderBrush="{DynamicResource SimpleButton.BorderBrush}"
                        BorderThickness="2"
                        Grid.Column="30" Grid.ColumnSpan="2"
                        Grid.Row="0" Grid.RowSpan="3"/>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="10"
