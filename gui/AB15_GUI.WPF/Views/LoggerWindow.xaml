<Window x:Class="AB15_GUI.WPF.Views.LoggerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AB15_GUI.WPF.Views"
        mc:Ignorable="d"
        Title="LoggerWindow" Height="450" Width="800">
    <Window.Resources>
        
    </Window.Resources>
    
    <Grid Background="{DynamicResource BackGroung}">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.IsSharedSizeScope="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="auto" SharedSizeGroup="A" />
                <ColumnDefinition Width="auto" SharedSizeGroup="A" />
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="SortingButton" Grid.Column="0" Content="&#x21C5;" FontSize="14" MinWidth="20" HorizontalAlignment="Stretch" Background="Gray"/>

            <Button x:Name="IncreaaseFont" Grid.Column="2" Content="+" FontSize="14" HorizontalAlignment="Stretch" Background="Gray"/>
            <Button x:Name="DecreaaseFont" Grid.Column="3" Content="-" FontSize="14" HorizontalAlignment="Stretch" Background="Gray"/>
            <TextBlock x:Name="FontSizeTextBox" Grid.Column="4" MinWidth="40" HorizontalAlignment="Stretch" Background="White"/>

            <Button x:Name="ThemChamge" Grid.Column="6" Content="Light" FontSize="14" Background="Gray"/>

            <TextBlock Text="Record format" Grid.Column="8" FontSize="14"/>
            <ComboBox Name="RecordFormat" Grid.Column="9" FontSize="14" HorizontalAlignment="Stretch" MinWidth="75" SelectedIndex="0">
                <TextBlock Text="Full"/>
                <TextBlock Text="Short"/>
            </ComboBox>

        </Grid>
    </Grid>
</Window>
