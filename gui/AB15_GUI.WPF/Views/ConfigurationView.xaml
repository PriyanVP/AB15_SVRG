                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot3Ch7SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="7" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot3Ch8SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>
                                    <!--#endregion-->

                                </Grid>
                                <!--#endregion-->

                                <!--#region Slot 4 sensor data -->
                                <Grid   Grid.Row="3"
                                        Grid.Column="0"
                                        Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="auto"/>
