                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>

                                    <!--#region texts -->
                                    <TextBlock  Text="Slot 4"
                                                Grid.Row="0" Grid.RowSpan="8"
                                                Grid.Column="0"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 1"
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 2"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 3"
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 4"
