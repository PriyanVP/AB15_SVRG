                                        <TextBlock  Text="{Binding Slot3Ch5SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="5" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
