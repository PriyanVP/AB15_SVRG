                                        <TextBlock  Text="{Binding Slot3Ch6SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="6" Grid.Column="2" 
                                                BorderThickness="1" 
