                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock  Text="group1"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
