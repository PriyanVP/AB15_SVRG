<Page x:Class="AB15_GUI.WPF.Views.ConfigurationView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AB15_GUI.WPF.Views"
      xmlns:cnvrt="clr-namespace:AB15_GUI.WPF.Views.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="900"
      Title="ConfigurationView"
      DataContext="{Binding ConfigurationViewModel, Source={StaticResource ViewModelLocator}}">

    <Page.Resources>
        <cnvrt:FaultFlagToColorConverter x:Key="FaultFlagToColorConverter"/>
        <cnvrt:IntToHexStringConverter x:Key="IntToHexCnvrt"/>
        <cnvrt:HexToIntConverter x:Key="HexToIntNoPrefixCnvrt"/>
    </Page.Resources>

    <Grid Background="{DynamicResource UI.BackGround}">

        <!-- Tab control -->
        <TabControl Name="ConfigurationPageTabControl" 
                    Grid.Row="1" Grid.Column="1" 
                    Background="{DynamicResource UI.BackGround}" BorderThickness="0">

            <!-- PSI tab -->
            <TabItem Header="PSI" FontSize="20" Style="{DynamicResource CustomTabItem}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" MinHeight="40"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto" MinHeight="40"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Borders set up -->
                    <Border     Grid.Row="2" Grid.RowSpan="2"
                                Grid.Column="1"
                                BorderThickness="0,1,1,0"
                                BorderBrush="{DynamicResource UI.SeparateLine}"/>

                    <Border     Grid.Row="2" Grid.RowSpan="2"
                                Grid.Column="2"
                                BorderThickness="0,1,0,0"
                                BorderBrush="{DynamicResource UI.SeparateLine}"/>

                    <Border     Grid.Row="1" Grid.RowSpan="3"
                                Grid.Column="0"
                                BorderThickness="0,0,1,0"
                                BorderBrush="{DynamicResource UI.SeparateLine}"/>

                    <Border     Grid.Row="0" 
                                Grid.Column="0" Grid.ColumnSpan="3"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource UI.SeparateLine}"/>
                    
                    <!-- Control buttons -->
                    <!--#region Bottom buttons -->
                    <Button Grid.Column="0"
                            Grid.Row="3"
                            Content="Read"
                            MinWidth="60"
                            Margin="5,0"
                            Command="{Binding ReadPsiSensorData}"
                            IsEnabled="{Binding ReadPsiSensorDataCommandEn}"
                            Style="{DynamicResource SimpleButton}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"/>

                    <Button Grid.Column="1"
                            Grid.Row="3"
                            Content="Read"
                            MinWidth="60"
                            Margin="5,0"
                            Command="{Binding ReadPsiStatus}"
                            IsEnabled="{Binding ReadPsiStatusCommandEn}"
                            Style="{DynamicResource SimpleButton}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"/>

                    <Button Grid.Column="2"
                            Grid.Row="3"
                            Content="Read"
                            MinWidth="60"
                            Margin="5,0"
                            Command="{Binding ReadMonitorSpiStatus}"
                            IsEnabled="{Binding ReadMonitorSpiStatusCommandEn}"
                            Style="{DynamicResource SimpleButton}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"/>
                    <!--#endregion-->

                    <!-- Top contol tab -->
                    <StackPanel Orientation="Horizontal"
                                Grid.Row="0"
                                Grid.Column="0" Grid.ColumnSpan="3"
                                HorizontalAlignment="Right"
                                Margin="0,3">

                        <Border Grid.Row="3" Grid.Column="3" 
                                BorderThickness="1" 
                                CornerRadius="5" 
                                BorderBrush="{DynamicResource Animation.Lines}" HorizontalAlignment="Stretch" 
                                Margin="4,2">
                            <Border.Background>
                                <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
                                    <Binding Path = "SyncPulseGeneretingStatus"/>
                                    <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
                                </MultiBinding>
                            </Border.Background>
                            <TextBlock Text="Sync pulse" 
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       Style="{DynamicResource TextBlockStyle}"
                                       MinWidth="200"/>
                        </Border>
                        
                        <Border Grid.Row="3" Grid.Column="3" 
                                BorderThickness="1" 
                                CornerRadius="5" 
                                BorderBrush="{DynamicResource Animation.Lines}" 
                                HorizontalAlignment="Stretch" 
                                Width="200"
                                Margin="10,2">
                            <Border.Background>
                                <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
                                    <Binding Path = "FlmFiringWithPsiStatus"/>
                                    <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
                                </MultiBinding>
                            </Border.Background>
                            <TextBlock Text="FLM Firing with PSI" 
                                       HorizontalAlignment="Center" 
                                       TextAlignment="Center"
                                       Style="{DynamicResource TextBlockStyle}"
                                       MinWidth="150"/>
                        </Border>
                        
                        <Border Grid.Row="3" Grid.Column="3" 
                                BorderThickness="1" 
                                BorderBrush="{DynamicResource Animation.Lines}" 
                                CornerRadius="5" HorizontalAlignment="Stretch"
                                Margin="4,2">
                            <Border.Background>
                                <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
                                    <Binding Path = "PsiTopStatus"/>
                                    <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
                                </MultiBinding>
                            </Border.Background>
                            <TextBlock Text="{Binding PsiTopStatusText, TargetNullValue='Deactivated'}" 
                                       HorizontalAlignment="Center" 
                                       TextAlignment="Center"
                                       Style="{DynamicResource TextBlockStyle}"
                                       MinWidth="150"/>
                        </Border>

                    </StackPanel>

                    <!-- PSI Configuratiion selecter register -->
                    <Grid   Grid.Row="1"
                            Grid.Column="1" 
                            Grid.ColumnSpan="2"
                            Margin="3,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <Grid   Grid.Row="0"
                                Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock  Grid.Row="0"
                                        Grid.Column="0"
                                        Text="PSI Configuration"
                                        Style="{DynamicResource TextBlockStyle}"
                                        FontWeight="Bold"
                                        Margin="5,0"/>

                            <TextBlock  Grid.Row="0"
                                        Grid.Column="0"
                                        Text="PSI Configuration"
                                        Style="{DynamicResource TextBlockStyle}"
                                        FontWeight="Bold"
                                        Margin="5,0"/>

                            <Border Grid.Row="0" Grid.Column="3" 
                                    BorderThickness="1" 
                                    CornerRadius="5" 
                                    BorderBrush="{DynamicResource Animation.Lines}" 
                                    HorizontalAlignment="Stretch" 
                                    Width="200"
                                    Margin="10,3">
                                <Border.Background>
                                    <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
                                        <Binding Path = "PsiDataReceivedStatus"/>
                                        <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
                                    </MultiBinding>
                                </Border.Background>
                                <TextBlock Text="PSI Data received" 
                                           HorizontalAlignment="Center" 
                                           TextAlignment="Center"
                                           Style="{DynamicResource TextBlockStyle}"
                                           MinWidth="150"/>
                            </Border>

                        </Grid>

                        <Grid   Grid.Row="1">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock  Grid.Row="0"
                                        Grid.Column="0"
                                        Text="PSI Supply"
                                        HorizontalAlignment="Left"
                                        Style="{DynamicResource TextBlockStyle}"/>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center">

                                <TextBlock  Text="0x"
                                            Style="{DynamicResource TextBlockStyle}"/>

                                <TextBox    Style="{DynamicResource TextBoxStyle}"
                                            IsEnabled="{Binding IsPsiPageEnabled}"
                                            Text="{Binding PsiSupply, Converter={StaticResource HexToIntNoPrefixCnvrt}, Mode=TwoWay}"
                                            PreviewTextInput="HexPsiConfigTextBox_PreviewTextInput"
                                            MinWidth="150"/>
                            </StackPanel>

                            <TextBlock  Grid.Row="1"
                                        Grid.Column="0"
                                        Text="PSI Gen Mask Sync"
                                        HorizontalAlignment="Left"
                                        Style="{DynamicResource TextBlockStyle}"/>

                            <StackPanel Grid.Row="1"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center">

                                <TextBlock  Text="0x"
                                            Style="{DynamicResource TextBlockStyle}"/>

                                <TextBox    Style="{DynamicResource TextBoxStyle}"
                                            IsEnabled="{Binding IsPsiPageEnabled}"
                                            Text="{Binding PsiGenMaskSync, Converter={StaticResource HexToIntNoPrefixCnvrt}, Mode=TwoWay}"
                                            PreviewTextInput="HexPsiConfigTextBox_PreviewTextInput"
                                            MinWidth="150"/>
                            </StackPanel>

                        </Grid>

                        <StackPanel Orientation="Horizontal"
                                    Grid.Row="3"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,0,3">
                            
                            <Button Content="Reset"
                                    Margin="10,0"
                                    Style="{DynamicResource SimpleButton}"
                                    Command="{Binding ResetPsiConfiguration}"
                                    IsEnabled="{Binding ResetPsiConfigurationCommandEn}"/>

                            <Button Content="Read"
                                    Margin="10,0"
                                    Style="{DynamicResource SimpleButton}"
                                    Command="{Binding ReadPsiConfiguration}"
                                    IsEnabled="{Binding ReadPsiConfigurationCommandEn}"/>

                            <Button Content="Write"
                                    Margin="10,0"
                                    Style="{DynamicResource SimpleButton}"
                                    Command="{Binding WritePsiConfiguration}"
                                    IsEnabled="{Binding WritePsiConfigurationCommandEn}"/>

                        </StackPanel>


                    </Grid>

                    <!-- PSI Sensor Data-->
                    <Grid   Grid.Row="1" Grid.RowSpan="2"
                            Grid.Column="0"
                            Margin="3,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock  Text="PSI Sensor Data"
                                    Style="{DynamicResource TextBlockStyle}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"/>

                        <ScrollViewer   Grid.Row="1"
                                        VerticalScrollBarVisibility="Visible"
                                        HorizontalScrollBarVisibility="Auto"
                                        Style="{DynamicResource ScrollViewer}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="1"
                                        BorderThickness="0,1,0,1"
                                        BorderBrush="{DynamicResource UI.SeparateLine}"/>

                                <Border Grid.Row="3"
                                        BorderThickness="0,1,0,1"
                                        BorderBrush="{DynamicResource UI.SeparateLine}"/>

                                <!--#region Slot 1 sensor data -->
                                <Grid   Grid.Row="0"
                                        Grid.Column="0"
                                        Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>

                                    <!--#region texts -->
                                    <TextBlock  Text="Slot 1"
                                                Grid.Row="0" Grid.RowSpan="8"
                                                Grid.Column="0"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 1"
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 2"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 3"
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 4"
                                                Grid.Row="3"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 5"
                                                Grid.Row="4"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 5"
                                                Grid.Row="5"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 7"
                                                Grid.Row="6"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 8"
                                                Grid.Row="7"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>
                                    <!--#endregion-->

                                    <!--#region data -->
                                    <Border     Grid.Row="0" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[0].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="1" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[1].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="2" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[2].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="3" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[3].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="4" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[4].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="5" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[5].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="6" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[6].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="7" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[7].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>
                                    <!--#endregion-->

                                </Grid>
                                <!--#endregion-->

                                <!--#region Slot 2 sensor data -->
                                <Grid   Grid.Row="1"
                                        Grid.Column="0"
                                        Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>

                                    <!--#region texts -->
                                    <TextBlock  Text="Slot 2"
                                                Grid.Row="0" Grid.RowSpan="8"
                                                Grid.Column="0"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 1"
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 2"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 3"
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 4"
                                                Grid.Row="3"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 5"
                                                Grid.Row="4"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 5"
                                                Grid.Row="5"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 7"
                                                Grid.Row="6"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 8"
                                                Grid.Row="7"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>
                                    <!--#endregion-->

                                    <!--#region data -->
                                    <Border     Grid.Row="0" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[8].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="1" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[9].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="2" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[10].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="3" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[11].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="4" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[12].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="5" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[13].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="6" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[14].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="7" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[15].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>
                                    <!--#endregion-->

                                </Grid>
                                <!--#endregion-->

                                <!--#region Slot 3 sensor data -->
                                <Grid   Grid.Row="2"
                                        Grid.Column="0"
                                        Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>

                                    <!--#region texts -->
                                    <TextBlock  Text="Slot 3"
                                                Grid.Row="0" Grid.RowSpan="8"
                                                Grid.Column="0"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 1"
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 2"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 3"
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 4"
                                                Grid.Row="3"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 5"
                                                Grid.Row="4"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 5"
                                                Grid.Row="5"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 7"
                                                Grid.Row="6"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 8"
                                                Grid.Row="7"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>
                                    <!--#endregion-->

                                    <!--#region data -->
                                    <Border     Grid.Row="0" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[16].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="1" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[17].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="2" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Path=PsiSensorData.PsiRegisterList[18].Data, Converter={StaticResource IntToHexCnvrt}, Mode=OneWay}"
                                                    HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                                    </Border>

                                    <Border     Grid.Row="3" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
