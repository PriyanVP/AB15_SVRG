                                    <ComboBoxItem>
                                        <TextBlock  Text="group2"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock  Text="group3"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                </ComboBox>

                                <TextBlock  Grid.Row="12" Grid.Column="0"
