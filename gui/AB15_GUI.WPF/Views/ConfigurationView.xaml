<Page x:Class="AB15_GUI.WPF.Views.ConfigurationView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AB15_GUI.WPF.Views"
      xmlns:cnvrt="clr-namespace:AB15_GUI.WPF.Views.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ConfigurationView">

    <Page.Resources>
        <cnvrt:FaultFlagToColorConverter x:Key="FaultFlagToColorConverter"/>
    </Page.Resources>

    <Grid Background="{DynamicResource UI.BackGround}">

        <!-- Tab control -->
        <TabControl Name="ConfigurationPageTabControl" 
                    Grid.Row="1" Grid.Column="1" 
                    Background="{DynamicResource UI.BackGround}" BorderThickness="0">

            <!-- Configuration tab -->
            <TabItem Header="PSI" FontSize="20" Style="{DynamicResource CustomTabItem}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" MinHeight="40"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto" MinHeight="40"/>
                    </Grid.RowDefinitions>

                    <Border     Grid.Row="2" Grid.RowSpan="2"
                                Grid.Column="1"
                                BorderThickness="0,1,1,0"
                                BorderBrush="{DynamicResource UI.SeparateLine}"/>

                    <Border     Grid.Row="2" Grid.RowSpan="2"
                                Grid.Column="2"
                                BorderThickness="0,1,0,0"
                                BorderBrush="{DynamicResource UI.SeparateLine}"/>

                    <Border     Grid.Row="1" Grid.RowSpan="3"
                                Grid.Column="0"
                                BorderThickness="0,1,1,0"
                                BorderBrush="{DynamicResource UI.SeparateLine}"/>

                    <Button Grid.Column="0"
                            Grid.Row="3"
                            Content="Read"
                            MinWidth="60"
                            Margin="5,0"
                            Command="{Binding ReadPSISensorDaaCommand}"
                            Style="{DynamicResource SimpleButton}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"/>

                    <Button Grid.Column="1"
                            Grid.Row="3"
                            Content="Read"
                            MinWidth="60"
                            Margin="5,0"
                            Command="{Binding ReadPSIStatusCommand}"
                            Style="{DynamicResource SimpleButton}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"/>

                    <Button Grid.Column="2"
                            Grid.Row="3"
                            Content="Read"
                            MinWidth="60"
                            Margin="5,0"
                            Command="{Binding ReadMonitorPSIStatusCommand}"
                            Style="{DynamicResource SimpleButton}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"/>
                    
                    <!-- top contol tab -->
                    <StackPanel Orientation="Horizontal"
                                Grid.Row="0"
                                Grid.Column="0" Grid.ColumnSpan="3"
                                HorizontalAlignment="Right">

                        <TextBlock Text="Sync puls generation -" 
                                       HorizontalAlignment="Center" 
                                       Style="{DynamicResource TextBlockStyle}"
                                       MinWidth="150"/>
                        
                        <Border Grid.Row="3" Grid.Column="3" 
                                BorderThickness="1" 
                                BorderBrush="{DynamicResource Animation.Lines}" HorizontalAlignment="Stretch" 
                                Margin="4,2">
                            <!--<Border.Background>
                                <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
                                    <Binding Path = "IsSyncPulsGeneretingStatus"/>
                                    <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
                                </MultiBinding>
                            </Border.Background>-->
                            <TextBlock Text="{Binding IsSyncPulsGeneretingStatusText}" 
                                       HorizontalAlignment="Center" 
                                       Style="{DynamicResource TextBlockStyle}"
                                       MinWidth="60"/>
                        </Border>
                        
                        <Border Grid.Row="3" Grid.Column="3" 
                                BorderThickness="1" 
                                BorderBrush="{DynamicResource Animation.Lines}" 
                                HorizontalAlignment="Stretch" 
                                Margin="10,2">
                            <!--<Border.Background>
                                <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
                                    <Binding Path = "FLMFiringWithPSIStatus"/>
                                    <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
                                </MultiBinding>
                            </Border.Background>-->
                            <TextBlock Text="FLM Firing with PSI" 
                                       HorizontalAlignment="Center" 
                                       Style="{DynamicResource TextBlockStyle}"
                                       MinWidth="150"/>
                        </Border>
                        
                        <Border Grid.Row="3" Grid.Column="3" 
                                BorderThickness="1" 
                                BorderBrush="{DynamicResource Animation.Lines}" 
                                CornerRadius="5" HorizontalAlignment="Stretch"
                                Margin="4,2">
                            <!--<Border.Background>
                                <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
                                    <Binding Path = "PSITopStatus"/>
                                    <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
                                </MultiBinding>
                            </Border.Background>-->
                            <TextBlock Text="{Binding PSITopStatusText}" 
                                       HorizontalAlignment="Center" 
                                       Style="{DynamicResource TextBlockStyle}"
                                       MinWidth="150"/>
                        </Border>

                    </StackPanel>

                    <!-- PSI Configuratiion selecter register -->
                    <Grid   Grid.Row="1"
                            Grid.Column="1" Grid.ColumnSpan="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <Grid   Grid.Row="0"
                                Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock  Grid.Row="0"
                                        Grid.Column="0"
                                        Text="PSI Configuration"
                                        Style="{DynamicResource TextBlockStyle}"
                                        FontWeight="Bold"
                                        Margin="5,0"/>

                        </Grid>

                        <StackPanel Orientation="Horizontal"
                                    Grid.Row="4"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,0,3">
                            
                            <Button Content="Write"
                                    Margin="10,0"
                                    Style="{DynamicResource SimpleButton}"
                                    Command="{Binding WritePSIConfigurationCommand}"/>

                            <Button Content="Read"
                                    Margin="10,0"
                                    Style="{DynamicResource SimpleButton}"
                                    Command="{Binding ReadPSIConfigurationCommand}"/>

                            <Button Content="Reset"
                                    Margin="10,0"
                                    Style="{DynamicResource SimpleButton}"
                                    Command="{Binding ResetPSIConfigurationCommand}"/>

                        </StackPanel>


                    </Grid>

                    <!-- PSI Sensor Data-->
                    <Grid   Grid.Row="1" Grid.RowSpan="2"
                            Grid.Column="0"
                            Margin="3,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock  Text="PSI Sensor Data"
                                    Style="{DynamicResource TextBlockStyle}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"/>

                        <ScrollViewer   Grid.Row="1"
                                        VerticalScrollBarVisibility="Visible"
                                        HorizontalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="1"
                                        BorderThickness="0,1,0,1"
                                        BorderBrush="{DynamicResource UI.SeparateLine}"/>

                                <Border Grid.Row="3"
                                        BorderThickness="0,1,0,1"
                                        BorderBrush="{DynamicResource UI.SeparateLine}"/>

                                <!--#region Slot 1 sensor data -->
                                <Grid   Grid.Row="0"
                                        Grid.Column="0"
                                        Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>

                                    <!--#region texts -->
                                    <TextBlock  Text="Slot 1"
                                                Grid.Row="0" Grid.RowSpan="8"
                                                Grid.Column="0"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 1"
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 2"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 3"
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 4"
                                                Grid.Row="3"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 5"
                                                Grid.Row="4"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 5"
                                                Grid.Row="5"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 7"
                                                Grid.Row="6"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 8"
                                                Grid.Row="7"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>
                                    <!--#endregion-->

                                    <!--#region data -->
                                    <Border     Grid.Row="0" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot1Ch1SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="1" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot1Ch2SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="2" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot1Ch3SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="3" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot1Ch4SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="4" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot1Ch5SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="5" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot1Ch6SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="6" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot1Ch7SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="7" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot1Ch8SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>
                                    <!--#endregion-->

                                </Grid>
                                <!--#endregion-->

                                <!--#region Slot 2 sensor data -->
                                <Grid   Grid.Row="1"
                                        Grid.Column="0"
                                        Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>

                                    <!--#region texts -->
                                    <TextBlock  Text="Slot 2"
                                                Grid.Row="0" Grid.RowSpan="8"
                                                Grid.Column="0"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 1"
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 2"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 3"
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 4"
                                                Grid.Row="3"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 5"
                                                Grid.Row="4"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 5"
                                                Grid.Row="5"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 7"
                                                Grid.Row="6"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 8"
                                                Grid.Row="7"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>
                                    <!--#endregion-->

                                    <!--#region data -->
                                    <Border     Grid.Row="0" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot2Ch1SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="1" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot2Ch2SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="2" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot2Ch3SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="3" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot2Ch4SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="4" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot2Ch5SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="5" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot2Ch6SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="6" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot2Ch7SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="7" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot2Ch8SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>
                                    <!--#endregion-->

                                </Grid>
                                <!--#endregion-->

                                <!--#region Slot 3 sensor data -->
                                <Grid   Grid.Row="2"
                                        Grid.Column="0"
                                        Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>

                                    <!--#region texts -->
                                    <TextBlock  Text="Slot 3"
                                                Grid.Row="0" Grid.RowSpan="8"
                                                Grid.Column="0"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 1"
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 2"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 3"
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 4"
                                                Grid.Row="3"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 5"
                                                Grid.Row="4"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 5"
                                                Grid.Row="5"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 7"
                                                Grid.Row="6"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>

                                    <TextBlock  Text="Ch 8"
                                                Grid.Row="7"
                                                Grid.Column="1"
                                                Style="{DynamicResource TextBlockStyle}"/>
                                    <!--#endregion-->

                                    <!--#region data -->
                                    <Border     Grid.Row="0" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot3Ch1SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="1" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot3Ch2SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

                                    <Border     Grid.Row="2" Grid.Column="2" 
                                                BorderThickness="1" 
                                                BorderBrush="{DynamicResource Animation.Lines}" 
                                                CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                                        <TextBlock  Text="{Binding Slot3Ch3SensorDataText}" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                                    FontSize="{Binding ElementName=TextScale, Path=FontSize, Mode=OneWay}"/>
                                    </Border>

