                                            Text="PSI supply" FontSize="16"
                                            Style="{DynamicResource CustomTextBlock}"
                                            Margin="5"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>

                                <CheckBox   Grid.Row="13" Grid.Column="1"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsEnabled="{Binding isPSIEnable}"
                                            Style="{DynamicResource ToggleSwitchStyle}" 
                                            IsChecked="{Binding IsChannelPSISupplyConfigurationEn}"/>

                                <TextBlock  Grid.Row="14" Grid.Column="0"
