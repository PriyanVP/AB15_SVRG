<Page x:Class="AB15_GUI.WPF.Views.ConfigurationView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AB15_GUI.WPF.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ConfigurationView">

    <Grid Background="{DynamicResource UI.BackGround}">

        <!-- Tab control -->
        <TabControl Name="ConfigurationPageTabControl" 
                    Grid.Row="1" Grid.Column="1" 
                    Background="{DynamicResource UI.BackGround}" BorderThickness="0">

            <!-- Configuration tab -->
            <TabItem Header="PSI" FontSize="20" Style="{DynamicResource CustomTabItem}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="5*"/>
                        <RowDefinition Height="5"/>
                    </Grid.RowDefinitions>
                    
                    <!--#region Slots blocks -->
                    <Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="5"/>
                        </Grid.RowDefinitions>

                        <Border BorderBrush="{DynamicResource UI.SeparateLine}"
                                Grid.Column="0" Grid.ColumnSpan="9" Grid.Row="2"
                                BorderThickness="0,0,0,1"/>

                        <!--#region Slot 1 Block -->
                        <Grid   Background="{Binding Slot1BlockBackground}"
                                Grid.Row="1" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock  Text="Slot 1"
                                        Grid.Column="1" Grid.ColumnSpan="2"
                                        Grid.Row="0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Style="{DynamicResource CustomTextBlock}"/>

                            <CheckBox   Grid.Column="0" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot1Ch1Checked}"
                                        Background="{Binding Slot1Ch1Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="1" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot1Ch2Checked}"
                                        Background="{Binding Slot1Ch2Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="2" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot1Ch3Checked}"
                                        Background="{Binding Slot1Ch3Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="3" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot1Ch4Checked}"
                                        Background="{Binding Slot1Ch4Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="0" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot1Ch5Checked}"
                                        Background="{Binding Slot1Ch5Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="1" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot1Ch6Checked}"
                                        Background="{Binding Slot1Ch6Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="2" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot1Ch7Checked}"
                                        Background="{Binding Slot1Ch7Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="3" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot1Ch8Checked}"
                                        Background="{Binding Slot1Ch8ackground}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>
                        </Grid>
                        <!--#endregion-->

                        <!--#region Slot 1 Block -->
                        <Grid   Background="{Binding Slot2BlockBackground}"
                                Grid.Row="1" Grid.Column="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock  Text="Slot 2"
                                        Grid.Column="1" Grid.ColumnSpan="2"
                                        Grid.Row="0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Style="{DynamicResource CustomTextBlock}"/>

                            <CheckBox   Grid.Column="0" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot2Ch1Checked}"
                                        Background="{Binding Slot2Ch1Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="1" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot2Ch2Checked}"
                                        Background="{Binding Slot2Ch2Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="2" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot2Ch3Checked}"
                                        Background="{Binding Slot2Ch3Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="3" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot2Ch4Checked}"
                                        Background="{Binding Slot2Ch4Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="0" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot2Ch5Checked}"
                                        Background="{Binding Slot2Ch5Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="1" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot2Ch6Checked}"
                                        Background="{Binding Slot2Ch6Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="2" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot2Ch7Checked}"
                                        Background="{Binding Slot2Ch7Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="3" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot2Ch8Checked}"
                                        Background="{Binding Slot2Ch8ackground}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>
                        </Grid>
                        <!--#endregion-->

                        <!--#region Slot 1 Block -->
                        <Grid   Background="{Binding Slot3BlockBackground}"
                                Grid.Row="1" Grid.Column="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock  Text="Slot 3"
                                        Grid.Column="1" Grid.ColumnSpan="2"
                                        Grid.Row="0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Style="{DynamicResource CustomTextBlock}"/>

                            <CheckBox   Grid.Column="0" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot3Ch1Checked}"
                                        Background="{Binding Slot3Ch1Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="1" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot3Ch2Checked}"
                                        Background="{Binding Slot3Ch2Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="2" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot3Ch3Checked}"
                                        Background="{Binding Slot3Ch3Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="3" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot3Ch4Checked}"
                                        Background="{Binding Slot3Ch4Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="0" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot3Ch5Checked}"
                                        Background="{Binding Slot3Ch5Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="1" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot3Ch6Checked}"
                                        Background="{Binding Slot3Ch6Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="2" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot3Ch7Checked}"
                                        Background="{Binding Slot3Ch7Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="3" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot3Ch8Checked}"
                                        Background="{Binding Slot3Ch8ackground}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>
                        </Grid>
                        <!--#endregion-->

                        <!--#region Slot 1 Block -->
                        <Grid   Background="{Binding Slot4BlockBackground}"
                                Grid.Row="1" Grid.Column="7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock  Text="Slot 4"
                                        Grid.Column="1" Grid.ColumnSpan="2"
                                        Grid.Row="0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Style="{DynamicResource CustomTextBlock}"/>

                            <CheckBox   Grid.Column="0" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot4Ch1Checked}"
                                        Background="{Binding Slot4Ch1Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="1" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot4Ch2Checked}"
                                        Background="{Binding Slot4Ch2Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="2" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot4Ch3Checked}"
                                        Background="{Binding Slot4Ch3Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="3" Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot4Ch4Checked}"
                                        Background="{Binding Slot4Ch4Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="0" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot4Ch5Checked}"
                                        Background="{Binding Slot4Ch5Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="1" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot4Ch6Checked}"
                                        Background="{Binding Slot4Ch6Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="2" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot4Ch7Checked}"
                                        Background="{Binding Slot4Ch7Background}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>

                            <CheckBox   Grid.Column="3" Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding isSlot4Ch8Checked}"
                                        Background="{Binding Slot4Ch8ackground}"
                                        IsEnabled="{Binding isPSIEnable}"
                                        IsHitTestVisible="False"/>
                        </Grid>
                        <!--#endregion-->

                    </Grid>
                    <!--#endregion-->

                    <Grid Grid.Row="2" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" MinHeight="50"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Choose chanel to configure -->
                        <ComboBox   Grid.Row="0" Grid.Column="0"
                                    IsEnabled="{Binding isPSIEnable}"
                                    SelectedIndex="{Binding ChannelConfigurationIndex}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <ComboBoxItem   IsSelected="True">
                                <TextBlock  Text="Channel 1"
                                            Style="{DynamicResource CustomTextBlock}"
                                            FontSize="16"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>
                            </ComboBoxItem>
                            <ComboBoxItem   IsSelected="True">
                                <TextBlock  Text="Channel 2"
                                            Style="{DynamicResource CustomTextBlock}"
                                            FontSize="16"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>
                            </ComboBoxItem>
                            <ComboBoxItem   IsSelected="True">
                                <TextBlock  Text="Channel 3"
                                            Style="{DynamicResource CustomTextBlock}"
                                            FontSize="16"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>
                            </ComboBoxItem>
                            <ComboBoxItem   IsSelected="True">
                                <TextBlock  Text="Channel 4"
                                            Style="{DynamicResource CustomTextBlock}"
                                            FontSize="16"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>
                            </ComboBoxItem>
                            <ComboBoxItem   IsSelected="True">
                                <TextBlock  Text="Channel 5"
                                            Style="{DynamicResource CustomTextBlock}"
                                            FontSize="16"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>
                            </ComboBoxItem>
                            <ComboBoxItem   IsSelected="True">
                                <TextBlock  Text="Channel 6"
                                            Style="{DynamicResource CustomTextBlock}"
                                            FontSize="16"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>
                            </ComboBoxItem>
                            <ComboBoxItem   IsSelected="True">
                                <TextBlock  Text="Channel 7"
                                            Style="{DynamicResource CustomTextBlock}"
                                            FontSize="16"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>
                            </ComboBoxItem>
                            <ComboBoxItem   IsSelected="True">
                                <TextBlock  Text="Channel 8"
                                            Style="{DynamicResource CustomTextBlock}"
                                            FontSize="16"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>
                            </ComboBoxItem>
                        </ComboBox>

                        <!-- Channel configuration table -->
                        <ScrollViewer Grid.Row="1" Grid.Column="0"
                                      VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                    <RowDefinition Height="auto" MinHeight="10"/>
                                </Grid.RowDefinitions>

                                <TextBlock  Grid.Row="0" Grid.Column="0"
                                            Text="Operating mode" FontSize="16"
                                            Style="{DynamicResource CustomTextBlock}"
                                            Margin="5"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>

                                <ComboBox   Grid.Row="0" Grid.Column="1"
                                            SelectedIndex="{Binding ChannelOperatingModeConfigurationIndex}"
                                            IsEnabled="{Binding isPSIEnable}"
                                            Margin="5">
                                    <ComboBoxItem IsSelected="True">
                                        <TextBlock  Text="Sync"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock  Text="Async"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                </ComboBox>
                                
                                <TextBlock  Grid.Row="1" Grid.Column="0"
                                            Text="Baud rate" FontSize="16"
                                            Style="{DynamicResource CustomTextBlock}"
                                            Margin="5"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>

                                <ComboBox   Grid.Row="1" Grid.Column="1"
                                            SelectedIndex="{Binding ChannelBaudRateConfigurationIndex}"
                                            IsEnabled="{Binding isPSIEnable}"
                                            Margin="5">
                                    <ComboBoxItem IsSelected="True">
                                        <TextBlock  Text="125 KB/s"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock  Text="189 KB/s"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                </ComboBox>

                                <TextBlock  Grid.Row="2" Grid.Column="0"
                                            Text="Correction mode" FontSize="16"
                                            Style="{DynamicResource CustomTextBlock}"
                                            Margin="5"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>

                                <ComboBox   Grid.Row="2" Grid.Column="1"
                                            SelectedIndex="{Binding ChannelCorrectionModeConfigurationIndex}"
                                            IsEnabled="{Binding isPSIEnable}"
                                            Margin="5">
                                    <ComboBoxItem>
                                        <TextBlock  Text="Parity"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem IsSelected="True">
                                        <TextBlock  Text="CRC"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                </ComboBox>

                                <TextBlock  Grid.Row="3" Grid.Column="0"
                                            Text="Slot" FontSize="16"
                                            Style="{DynamicResource CustomTextBlock}"
                                            Margin="5"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>

                                <ComboBox   Grid.Row="3" Grid.Column="1"
                                            SelectedIndex="{Binding ChannelCorrectionModeConfigurationIndex}"
                                            IsEnabled="{Binding isPSIEnable}"
                                            Margin="5">
                                    <ComboBoxItem IsSelected="True">
                                        <TextBlock  Text="1 Timeslot"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock  Text="2 Timeslots"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock  Text="3 Timeslots"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock  Text="4 Timeslots"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                </ComboBox>

                                <TextBlock  Grid.Row="4" Grid.Column="0"
                                            Text="Transmission mode" FontSize="16"
                                            Style="{DynamicResource CustomTextBlock}"
                                            Margin="5"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>

                                <ComboBox   Grid.Row="4" Grid.Column="1"
                                            SelectedIndex="{Binding ChannelTransmissionModeConfigurationIndex}"
                                            IsEnabled="{Binding isPSIEnable}"
                                            Margin="5">
                                    <ComboBoxItem IsSelected="True">
                                        <TextBlock  Text="Keep on ending"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock  Text="Discard"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                </ComboBox>

                                <TextBlock  Grid.Row="5" Grid.Column="0"
                                            Text="Data filter delay" FontSize="16"
                                            Style="{DynamicResource CustomTextBlock}"
                                            Margin="5"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>

                                <ComboBox   Grid.Row="5" Grid.Column="1"
                                            SelectedIndex="{Binding ChannelDataFilterDelayConfigurationIndex}"
                                            IsEnabled="{Binding isPSIEnable}"
                                            Margin="5">
                                    <ComboBoxItem IsSelected="True">
                                        <TextBlock  Text="0.5 Usec"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock  Text="0.75 Usec"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock  Text="1 Usec"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                </ComboBox>
                                
                                <TextBlock  Grid.Row="6" Grid.Column="0"
                                            Text="Enale hysteresis" FontSize="16"
                                            Style="{DynamicResource CustomTextBlock}"
                                            Margin="5"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>

                                <CheckBox   Grid.Row="6" Grid.Column="1"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Style="{DynamicResource ToggleSwitchStyle}" 
                                            IsChecked="{Binding IsChannelHysteresisConfigurationEn}"
                                            IsEnabled="{Binding isPSIDebugEnable}"/>

                                
                                <TextBlock  Grid.Row="7" Grid.Column="0"
                                            Text="Current regulation" FontSize="16"
                                            Style="{DynamicResource CustomTextBlock}"
                                            Margin="5"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            IsEnabled="{Binding isPSIDebugEnable}"/>

                                <ComboBox   Grid.Row="7" Grid.Column="1"
                                            SelectedIndex="{Binding ChannelCurrentRegulationModeConfigurationIndex}"
                                            IsEnabled="{Binding isPSIDebugEnable}"
                                            Margin="5" Name="CurrentRegulationComboBox">
                                    <ComboBoxItem IsSelected="True">
                                        <TextBlock  Text="continuous regulation + asymmetric up/down counter"
                                                    TextWrapping="Wrap"
                                                    Style="{DynamicResource CustomTextBlock}"
                                                    MaxWidth="{Binding ElementName=CurrentRegulationComboBox, Path=ActualWidth}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock  Text="Regulation is blanked during data words +symmetric up/down counter"
