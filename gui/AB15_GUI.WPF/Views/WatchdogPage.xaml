                            <!--<Border.Background>
                                <MultiBinding Converter = "{StaticResource StatusToColorConverter}">
                                    <Binding Path = "WD1TimerFaultStatus"/>
                                    <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
                                </MultiBinding>
                            </Border.Background>-->
                            <Viewbox>
                                <TextBlock Text="WD1 Timer Fault" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"/>
                            </Viewbox>
                        </Border>

