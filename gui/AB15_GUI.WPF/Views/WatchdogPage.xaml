      mc:Ignorable="d" 
      
      d:DesignHeight="450" d:DesignWidth="800"
      Title="WatchDog">
    <Page.Resources>
        <cnvrt:StatusToColorConverter x:Key="StatusToColorConverter"/>
    </Page.Resources>

    <Grid Background="{DynamicResource UI.BackGround}">

        <Grid.RowDefinitions>
            <RowDefinition Height="auto" MinHeight="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>


        <TabControl Name="WatchdogPageControl" 
