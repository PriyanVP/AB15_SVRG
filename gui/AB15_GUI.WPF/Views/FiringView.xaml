                            <ListView   Name="ASIC3ChannelMonitor" 
                                        ItemsSource="{Binding ASIC3ChannelMonitorTable}"
                                        ItemContainerStyle="{DynamicResource ListViewItemStyle}" 
                                        FontSize="20">
                                <ListView.ItemTemplate>
