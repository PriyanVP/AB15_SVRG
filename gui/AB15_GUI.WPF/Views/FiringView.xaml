                                            Text="Criteria" HorizontalAlignment="Center">

                                </TextBlock>

                                <TextBlock Grid.Column="2" Margin="0,0,5,0" FontSize="16"
                                            Text="Status" HorizontalAlignment="Center">
                                </TextBlock>

                            </Grid>
                            <ListView   Name="ASIC1Monitor" 
                                        ItemsSource="{Binding ASIC1MonitorTable}"
                                        ItemContainerStyle="{DynamicResource ListViewItemStyle}" 
                                        FontSize="20">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
