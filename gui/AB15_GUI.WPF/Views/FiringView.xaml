                                        Storyboard.TargetProperty="Width"
                                        BeginTime="0:0:0"
                                        To="200" From="0"
                                        Duration="0:0:0.2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
