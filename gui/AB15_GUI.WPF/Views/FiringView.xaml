<Page x:Class="AB15_GUI.WPF.Views.Firing"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AB15_GUI.WPF.Views"
      xmlns:custom="clr-namespace:AB15_GUI.WPF.Views.Components"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="900"
      Title="Firing"
      DataContext="{Binding FiringViewModel, Source={StaticResource ViewModelLocator}}">

    <Grid Background="{DynamicResource UI.BackGround}">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto" MinHeight="100"/>
            <RowDefinition Height="auto" MinHeight="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto" MinWidth="100"/>
                <ColumnDefinition Width="auto" MinWidth="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>


                <!--#region Asic buttons -->
                <Border Grid.Row="0" Grid.Column="1" BorderThickness="1" 
                        BorderBrush="{DynamicResource Animation.Lines}" 
                        CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                    <!--<Border.Background>
                        <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
                            <Binding Path = "WD1QAFaultStatus"/>
                            <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
                        </MultiBinding>
                    </Border.Background>-->
                    <TextBlock Text="ASIC 1" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                               FontSize="20"/>
                </Border>

                <Border Grid.Row="0" Grid.Column="2" BorderThickness="1" 
                        BorderBrush="{DynamicResource Animation.Lines}" 
                        CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                    <!--<Border.Background>
                        <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
                            <Binding Path = "WD1QAFaultStatus"/>
                            <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
                        </MultiBinding>
                    </Border.Background>-->
                    <TextBlock Text="ASIC 2" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                               FontSize="20"/>
                </Border>

                <Border Grid.Row="0" Grid.Column="3" BorderThickness="1" 
                        BorderBrush="{DynamicResource Animation.Lines}" 
                        CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                    <!--<Border.Background>
                        <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
                            <Binding Path = "WD1QAFaultStatus"/>
                            <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
                        </MultiBinding>
                    </Border.Background>-->
                    <TextBlock Text="ASIC 3" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                               FontSize="20"/>
                </Border>

                <Border Grid.Row="0" Grid.Column="4" BorderThickness="1" 
                        BorderBrush="{DynamicResource Animation.Lines}" 
                        CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                    <!--<Border.Background>
                        <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
                            <Binding Path = "WD1QAFaultStatus"/>
                            <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
                        </MultiBinding>
                    </Border.Background>-->
                    <TextBlock Text="ASIC 4" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                               FontSize="20"/>
                </Border>
                <!--#endregion-->


                <TextBlock Grid.Row="1" Grid.Column="0"
                    Text="VH voltage at 11 nodes"/>

                <TextBlock Grid.Row="1" Grid.Column="1" Text="OK/Error"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="OK/Error"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="OK/Error"/>
                <TextBlock Grid.Row="1" Grid.Column="4" Text="OK/Error"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0"
                    Text="Junction temp"/>

                <TextBlock Grid.Row="2" Grid.Column="1" Text="OK/Error"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="OK/Error"/>
                <TextBlock Grid.Row="2" Grid.Column="3" Text="OK/Error"/>
                <TextBlock Grid.Row="2" Grid.Column="4" Text="OK/Error"/>
                
                <TextBlock Grid.Row="3" Grid.Column="0"
                    Text="Squib/LEA loads connected"/>

                <TextBlock Grid.Row="3" Grid.Column="1" Text="OK/Error"/>
                <TextBlock Grid.Row="3" Grid.Column="2" Text="OK/Error"/>
                <TextBlock Grid.Row="3" Grid.Column="3" Text="OK/Error"/>
                <TextBlock Grid.Row="3" Grid.Column="4" Text="OK/Error"/>

                <TextBox Grid.Row="4" Grid.Column="0"
                    Text="Error list PLaceholder" FontSize="12"/>

                <TextBlock Grid.Row="4" Grid.Column="1" Text="Pplaceholder" Background="LightGray" Margin="3"/>
                <TextBlock Grid.Row="4" Grid.Column="2" Text="Pplaceholder" Background="LightGray" Margin="3"/>
                <TextBlock Grid.Row="4" Grid.Column="3" Text="Pplaceholder" Background="LightGray" Margin="3"/>
                <TextBlock Grid.Row="4" Grid.Column="4" Text="Pplaceholder" Background="LightGray" Margin="3"/>

            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" Background="LightBlue">
                    <TextBlock Text="AUTARKY PLACEHOLDER"/>
                </Border>

                <StackPanel Grid.Row="0" Grid.Column="3"
                    Orientation="Vertical" VerticalAlignment="Stretch">
                    <TextBox Text="CAP VALUE" 
                             FontSize="12"/>
                    <TextBox Text="CAP Reference" 
                             FontSize="12"/>
                    <Button Content="Run test"/>
                </StackPanel>
                
                <!--#region Additional status -->
                <Border Grid.Row="1" Grid.Column="0" BorderThickness="1" 
                        BorderBrush="{DynamicResource Animation.Lines}" 
                        CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                    <!--<Border.Background>
                            <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
                                <Binding Path = "WD1QAFaultStatus"/>
                                <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
                            </MultiBinding>
                        </Border.Background>-->
                    <TextBlock Text="Aditional status" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
                                FontSize="10"/>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" BorderThickness="1" 
                        BorderBrush="{DynamicResource Animation.Lines}" 
                        CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                    <!--<Border.Background>
        <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
            <Binding Path = "WD1QAFaultStatus"/>
            <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
        </MultiBinding>
    </Border.Background>-->
                    <TextBlock Text="Aditional status" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
            FontSize="10"/>
                </Border>

                <Border Grid.Row="1" Grid.Column="2" BorderThickness="1" 
                        BorderBrush="{DynamicResource Animation.Lines}" 
                        CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                    <!--<Border.Background>
        <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
            <Binding Path = "WD1QAFaultStatus"/>
            <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
        </MultiBinding>
    </Border.Background>-->
                    <TextBlock Text="Aditional status" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
            FontSize="10"/>
                </Border>

                <Border Grid.Row="2" Grid.Column="0" BorderThickness="1" 
                        BorderBrush="{DynamicResource Animation.Lines}" 
                        CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                    <!--<Border.Background>
        <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
            <Binding Path = "WD1QAFaultStatus"/>
            <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
        </MultiBinding>
    </Border.Background>-->
                    <TextBlock Text="Aditional status" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
            FontSize="10"/>
                </Border>

                <Border Grid.Row="2" Grid.Column="1" BorderThickness="1" 
                        BorderBrush="{DynamicResource Animation.Lines}" 
                        CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                    <!--<Border.Background>
        <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
            <Binding Path = "WD1QAFaultStatus"/>
            <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
        </MultiBinding>
    </Border.Background>-->
                    <TextBlock Text="Aditional status" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
            FontSize="10"/>
                </Border>

                <Border Grid.Row="2" Grid.Column="2" BorderThickness="1" 
                        BorderBrush="{DynamicResource Animation.Lines}" 
                        CornerRadius="5" HorizontalAlignment="Stretch" Margin="2">
                    <!--<Border.Background>
        <MultiBinding Converter = "{StaticResource FaultFlagToColorConverter}">
            <Binding Path = "WD1QAFaultStatus"/>
            <Binding Path = "IsDarkTheme" Source="{StaticResource SharedThemeState}"/>
        </MultiBinding>
    </Border.Background>-->
                    <TextBlock Text="Aditional status" HorizontalAlignment="Center" Style="{DynamicResource TextBlockStyle}"
            FontSize="10"/>
                </Border>
                <!--#endregion-->


                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Vertical">
                    <TextBlock 
                        Text="Mode" HorizontalAlignment="Left"/>
                    <Button Grid.Row="1" Grid.RowSpan="2" Grid.Column="0"
                        Content="ASIC mode"/>
                </StackPanel>


                <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"  Orientation="Vertical">
                    <TextBlock Grid.Row="0" Grid.Column="1"
                        Text="Runtime configuration" HorizontalAlignment="Center"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                        <CheckBox/>
                        <TextBlock Text="Enable alternative mode" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Row="2" Grid.Column="1"
                        Content="Apply"/>
                </StackPanel>

            </Grid>
            
            
        </Grid>

    </Grid>
</Page>
