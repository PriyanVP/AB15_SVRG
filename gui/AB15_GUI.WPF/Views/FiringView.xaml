                                <TextBlock  Grid.Column="3" Margin="0,0,5,0" FontSize="16"
                                            Text="Status" HorizontalAlignment="Center">
                                </TextBlock>

                            </Grid>
                            <ListView   Name="ASIC2ChannelMonitor" 
                                        ItemsSource="{Binding ASIC2ChannelMonitorTable}"
                                        ItemContainerStyle="{DynamicResource ListViewItemStyle}" 
                                        FontSize="20">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="5" />
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="5" />
                                            </Grid.ColumnDefinitions>

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto"/>
