                            <ListView   Name="ASIC4Monitor" 
                                        ItemsSource="{Binding ASIC4MonitorTable}"
                                        ItemContainerStyle="{DynamicResource ListViewItemStyle}" 
                                        FontSize="20">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="5" />
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="5" />
                                            </Grid.ColumnDefinitions>

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto"/>
                                                <RowDefinition Height="2"/>
                                                <RowDefinition Height="1"/>
                                            </Grid.RowDefinitions>

                                            <Canvas Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5" Background="{DynamicResource UI.SeparateLine}"/>

                                            <TextBlock Grid.Column="2" Margin="0,0,5,0" FontSize="20"
                                                        Text="{Binding CriteriaName}"
                                                        HorizontalAlignment="Center">
                                            </TextBlock>

                                            <TextBlock Grid.Column="3" Margin="0,0,5,0" FontSize="20"
                                                        Text="{Binding CriteriaStatus}"
                                                        HorizontalAlignment="Center">
                                            </TextBlock>

                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="3" BorderThickness="1" BorderBrush="Black" Margin="5">
                        <StackPanel Orientation="Vertical">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="5" />
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="2"/>
                                    <RowDefinition Height="1"/>
                                </Grid.RowDefinitions>

                                <Canvas Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Background="{DynamicResource UI.SeparateLine}"/>

                                <TextBlock  Grid.Column="1" Margin="0,0,5,0" FontSize="16"
                                            Text="#" HorizontalAlignment="Center">
                                </TextBlock>

                                <TextBlock  Grid.Column="2" Margin="0,0,5,0" FontSize="16"
                                            Text="Identifier" HorizontalAlignment="Center">
                                </TextBlock>

                                <TextBlock  Grid.Column="3" Margin="0,0,5,0" FontSize="16"
                                            Text="Status" HorizontalAlignment="Center">
                                </TextBlock>

                            </Grid>
                            <ListView   Name="ASIC4ChannelMonitor" 
                                        ItemsSource="{Binding ASIC4ChannelMonitorTable}"
                                        ItemContainerStyle="{DynamicResource ListViewItemStyle}" 
                                        FontSize="20">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="5" />
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="5" />
                                            </Grid.ColumnDefinitions>

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto"/>
                                                <RowDefinition Height="2"/>
                                                <RowDefinition Height="1"/>
                                            </Grid.RowDefinitions>

                                            <Canvas Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5" Background="{DynamicResource UI.SeparateLine}"/>

                                            <TextBlock Grid.Column="3" Margin="0,0,5,0" FontSize="20"
                                                        Text="{Binding ID}"
                                                        HorizontalAlignment="Center">
                                            </TextBlock>

                                            <TextBlock Grid.Column="2" Margin="0,0,5,0" FontSize="20"
                                                        Text="{Binding Identifier}"
                                                        HorizontalAlignment="Center">
                                            </TextBlock>

                                            <TextBlock Grid.Column="3" Margin="0,0,5,0" FontSize="20"
                                                        Text="{Binding Status}"
                                                        HorizontalAlignment="Center">
                                            </TextBlock>

                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                </Grid>

            </TabItem>

            <TabItem Header="Firing" FontSize="20" Style="{DynamicResource CustomTabItem}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="5"/>
                    </Grid.RowDefinitions>

                    <StackPanel VerticalAlignment="Bottom"
                                Grid.Column="1" Grid.Row="2" Orientation="Vertical">
                        <Button Command="{Binding FireSimultaneouslyCommand}"
                                Content="Fire simultaneous" Margin="5"
                                Style="{DynamicResource SimpleButton}"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="1">

                        <StackPanel Orientation="Horizontal">
                            <CheckBox Style="{DynamicResource ToggleSwitchStyle}" 
                                      IsChecked="{Binding VH1aCurrentSinkEnable}"/>
                            <TextBlock Text="VH1a Current Sink"
                                       Margin="5"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <CheckBox Style="{DynamicResource ToggleSwitchStyle}" 
                                      IsChecked="{Binding VH2CurrentSinkEnable}"/>
                            <TextBlock Text="VH2 Current Sink"
                                       Margin="5"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <CheckBox Style="{DynamicResource ToggleSwitchStyle}" 
                                      IsChecked="{Binding ReduceCurrentEnable}"/>
                            <StackPanel     Orientation="Vertical">
                                <TextBlock  Text="Reduced Current alternative mode"
                                            Margin="5,5,5,5"/>
                            </StackPanel>
                        </StackPanel>

                        <ComboBox SelectedIndex="{Binding FiringSelectedMode}" Margin="5">
                            <ComboBoxItem IsSelected="True">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="A.1 "/>
                                    <TextBlock Text=" - Fire 1 (all)"/>
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="B.1 "/>
                                    <TextBlock Text=" - Fire 1"/>
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="B.2 "/>
                                    <TextBlock Text=" - Fire 2 (all)"/>
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="C.1 "/>
                                    <TextBlock Text=" - Fire 1"/>
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="C.1a"/>
                                    <TextBlock Text=" - Fire 1, soft firing"/>
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="C.2a"/>
                                    <TextBlock Text=" - Fire 2 (all), soft firing"/>
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="D.1 "/>
                                    <TextBlock Text=" - Fire 1"/>
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="D.2 "/>
                                    <TextBlock Text=" - FIre 2 (all)"/>
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="E.5 "/>
                                    <TextBlock Text=" - Fire 5 (1 on each module"/>
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="E.10"/>
                                    <TextBlock Text=" - Fire 10 (all, on each module)"/>
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="F.20"/>
                                    <TextBlock Text=" - Fire 20 (all)"/>
                                </StackPanel>
                            </ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="2" BorderThickness="1" BorderBrush="Black" Margin="5">
                        <StackPanel Orientation="Vertical">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="120" MinWidth="80"/>
                                    <ColumnDefinition Width="100" MinWidth="80"/>
                                    <ColumnDefinition Width="100" MinWidth="80"/>
                                    <ColumnDefinition Width="120" MinWidth="80"/>
                                    <ColumnDefinition Width="120" MinWidth="80"/>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="5" />
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="2"/>
                                    <RowDefinition Height="1"/>
                                </Grid.RowDefinitions>

                                <Canvas Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="7" Background="{DynamicResource UI.SeparateLine}"/>

                                <TextBlock  Grid.Column="1" Margin="0,0,5,0" FontSize="20"
                                            Text="#" HorizontalAlignment="Center">
                                 
                                </TextBlock>

                                <TextBlock Grid.Column="2" Margin="0,0,5,0" FontSize="20"
                                               Text="Identifier" HorizontalAlignment="Center">
                                </TextBlock>

                                <TextBlock Grid.Column="3" Margin="0,0,5,0" FontSize="20"
                                               Text="ToFire" HorizontalAlignment="Center">
                                </TextBlock>

                                <TextBlock Grid.Column="4" Margin="0,0,5,0" FontSize="20"
                                               Text="WasFired" HorizontalAlignment="Center">
                                </TextBlock>

                                <TextBlock Grid.Column="5" Margin="0,0,5,0" FontSize="20"
                                               Text="Count Hight" HorizontalAlignment="Center">
                                </TextBlock>

                                <TextBlock Grid.Column="6" Margin="0,0,5,0" FontSize="20"
                                               Text="Count Low" HorizontalAlignment="Center">
                                </TextBlock>
                            </Grid>
                            <ListView   Name="FiringResultTableView" 
                                ItemsSource="{Binding FiringResultTable}"
                                ItemContainerStyle="{DynamicResource ListViewItemStyle}" 
                                FontSize="20">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="5" />
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="120" MinWidth="80"/>
                                                <ColumnDefinition Width="100" MinWidth="80"/>
                                                <ColumnDefinition Width="100" MinWidth="80"/>
                                                <ColumnDefinition Width="120" MinWidth="80"/>
                                                <ColumnDefinition Width="120" MinWidth="80"/>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="5" />
                                            </Grid.ColumnDefinitions>

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto"/>
                                                <RowDefinition Height="2"/>
                                                <RowDefinition Height="1"/>
                                            </Grid.RowDefinitions>

                                            <Canvas Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="7" Background="{DynamicResource UI.SeparateLine}"/>

                                            <TextBlock  Grid.Column="1" Margin="0,0,5,0" FontSize="20">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0}.{1}">
                                                        <Binding Path="ASICID" />
                                                        <Binding Path="ChannelID" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>

                                            <TextBlock Grid.Column="2" Margin="0,0,5,0" FontSize="20"
                                               Text="{Binding Identifier}"
                                                       HorizontalAlignment="Center">
                                            </TextBlock>

                                            <TextBlock Grid.Column="3" Margin="0,0,5,0" FontSize="20"
                                               Text="{Binding ToFire}"
                                                       HorizontalAlignment="Center">
                                            </TextBlock>

                                            <TextBlock Grid.Column="4" Margin="0,0,5,0" FontSize="20"
                                               Text="{Binding WasFired}"
                                                       HorizontalAlignment="Center">
                                            </TextBlock>

                                            <TextBlock Grid.Column="5" Margin="0,0,5,0" FontSize="20"
                                               Text="{Binding FiringCntHigh}"
                                                       HorizontalAlignment="Center">
                                            </TextBlock>

                                            <TextBlock Grid.Column="6" Margin="0,0,5,0" FontSize="20"
                                               Text="{Binding FiringCntLow}"
                                                       HorizontalAlignment="Center">
                                            </TextBlock>

                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>



                </Grid>

            </TabItem>
        </TabControl>


    </Grid>
</Page>
