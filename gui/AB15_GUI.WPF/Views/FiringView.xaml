                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="5" />
                                            </Grid.ColumnDefinitions>

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto"/>
                                                <RowDefinition Height="2"/>
                                                <RowDefinition Height="1"/>
                                            </Grid.RowDefinitions>

                                            <Canvas Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Background="{DynamicResource UI.SeparateLine}"/>

                                            <TextBlock Grid.Column="2" Margin="0,0,5,0" FontSize="20"
                                                        Text="{Binding CriteriaName}"
                                                        HorizontalAlignment="Center">
                                            </TextBlock>

                                            <TextBlock Grid.Column="3" Margin="0,0,5,0" FontSize="20"
