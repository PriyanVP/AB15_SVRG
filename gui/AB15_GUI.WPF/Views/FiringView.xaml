                                        Storyboard.TargetProperty="Width"
                                        BeginTime="0:0:0"
                                        From="200" To="0"
                                        Duration="0:0:0.2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="ToggleButton.Checked">
